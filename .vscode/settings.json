{
  "css.lint.unknownAtRules": "ignore",
  "editor.tabSize": 4,
  "editor.fontFamily": "JetBrains Mono, Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.minimap.enabled": false,
  "terminal.integrated.fontFamily": "JetBrains Mono",
  "debug.console.fontFamily": "JetBrains Mono",
  "scm.inputFontFamily": "JetBrains Mono",
  "apc.font.family": "JetBrains Mono",
  "apc.stylesheet": {
    ".monaco-workbench": "font-family: 'JetBrains Mono'"
  },
  "editor.smoothScrolling": true,
  "workbench.list.smoothScrolling": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.renderWhitespace": "none",
  "breadcrumbs.enabled": false,
  "files.autoSave": "onFocusChange",
  "editor.stickyScroll.enabled": true,
  "editor.formatOnSave": true,
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#dfaec3",
    "activityBar.background": "#dfaec3",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#5a8936",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#15202b99",
    "editorGroup.border": "#dfaec3",
    "panel.border": "#dfaec3",
    "sash.hoverBorder": "#dfaec3",
    "sideBar.border": "#dfaec3",
    "statusBar.background": "#d189a8",
    "statusBar.border": "#d189a8",
    "statusBar.debuggingBackground": "#89d1b2",
    "statusBar.debuggingBorder": "#89d1b2",
    "statusBar.debuggingForeground": "#15202b",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#c3648d",
    "statusBarItem.remoteBackground": "#d189a8",
    "statusBarItem.remoteForeground": "#15202b",
    "tab.activeBorder": "#dfaec3",
    "titleBar.activeBackground": "#d189a8",
    "titleBar.activeForeground": "#15202b",
    "titleBar.border": "#d189a8",
    "titleBar.inactiveBackground": "#d189a899",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.remoteColor": "#d189a8"
}
