#!/usr/bin/env bash
# ==================================================
# profilarr-db - direnv configuration
# ==================================================
# Automatically loads environment variables when entering directory
# Run 'direnv allow' after creating/modifying this file

# Load .env file if it exists
# if [[ -f .env ]]; then
#     set -a  # Mark all variables for export
#     source .env
#     set +a  # Stop marking for export
# fi

# Load .env file if it exists using dotenvx
if [[ -f .env.local ]]; then
  set -a # Mark all variables for export
  eval "$(dotenvx get -q -f .env.local --format eval)"
  set +a # Stop marking for export
fi

# ================================================================
# Project-specific environment configuration
# ================================================================

# Uncomment and customize as needed:

# Add project bin directory to PATH
# export PATH="$PWD/bin:$PATH"

# Add node_modules/.bin to PATH for npm/yarn projects
# export PATH="$PWD/node_modules/.bin:$PATH"

# Set project root
# export PROJECT_ROOT="$PWD"

# Language/runtime version management
# Example for Node.js with nvm:
# use node 20.0.0

# Example for Python with virtualenv:
# Option 1: Use direnv's layout python (recommended - auto-manages venv)
# layout python python3
#
# Option 2: Use existing virtualenv
# export VIRTUAL_ENV="$PWD/.venv"
# export PATH="$VIRTUAL_ENV/bin:$PATH"
#
# Option 3: Specific Python version
# layout python python3.11

# Example for Ruby with rbenv:
# use ruby 3.2.0

# Example for Go:
# export GOPATH="$PWD/.go"
# export PATH="$GOPATH/bin:$PATH"

# Cloud provider configurations
# export AWS_PROFILE="project-dev"
# export GCP_PROJECT="my-project"
# export AZURE_SUBSCRIPTION_ID="..."

# Development tool configurations
# export DOCKER_BUILDKIT=1
# export COMPOSE_profilarr-db="project-name"

# Custom aliases for this project (use 'watch_file' to reload on changes)
# watch_file package.json
# watch_file Makefile

