---
// Native documentation version selector, injected above the Starlight sidebar.
// The active version is resolved at build time from DOCS_VERSION (set per build by
// scripts/build-versions.mjs); options navigate to each version's base root
// (navigate-to-base semantics — see /app/docs-versioning/).
import versions from '../../versions.json';

const fallback = versions.find((v) => v.default) ?? versions[0];
const currentId = process.env.DOCS_VERSION ?? fallback.id;
const current = versions.find((v) => v.id === currentId) ?? fallback;
---

<div class="version-select">
	<label class="sr-only" for="praxrr-version-select">Documentation version</label>
	<select id="praxrr-version-select" onchange="location.href=this.value">
		{
			versions.map((v) => (
				<option value={v.base} selected={v.id === current.id}>
					{v.label}
				</option>
			))
		}
	</select>
</div>

<style>
	.version-select {
		padding: 0.5rem 0 0.75rem;
	}
	.version-select select {
		width: 100%;
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
